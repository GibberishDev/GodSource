[gd_resource type="ShaderMaterial" format=3 uid="uid://cyw7pcp6fvn6f"]

[sub_resource type="Shader" id="Shader_443mo"]
code = "shader_type spatial;
render_mode unshaded, depth_test_disabled;
stencil_mode read, compare_greater, 1;

uniform float outline_width: hint_range(0.0, 128.0, 1.0) = 2.0;
uniform vec4 outline_color : source_color = vec4(1.0,1.0,0.0,1.0);

void vertex() {
	vec4 clip_position = PROJECTION_MATRIX * (MODELVIEW_MATRIX * vec4(VERTEX, 1.0));
	vec3 clip_normal = mat3(PROJECTION_MATRIX) * (mat3(MODELVIEW_MATRIX) * NORMAL);
	vec2 offset = normalize(clip_normal.xy) / VIEWPORT_SIZE * clip_position.w * outline_width * 2.0;
	clip_position.xy += offset;
	POSITION = clip_position;
}

void fragment() {
	ALBEDO = outline_color.rgb;
	ALPHA = outline_color.a;
}"

[resource]
render_priority = 0
shader = SubResource("Shader_443mo")
shader_parameter/outline_width = 2.0
shader_parameter/outline_color = Color(1, 1, 0, 1)
