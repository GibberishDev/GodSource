; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="GodSource"
config/version="0.0.1"
run/main_scene="res://debug_scene.tscn"
config/features=PackedStringArray("4.3", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

State="*res://game/classes/PlayerState.gd"
ClientSettings="*res://game/classes/ClientState.gd"

[display]

window/size/mode=2

[editor_plugins]

enabled=PackedStringArray("res://addons/Todo_Manager/plugin.cfg", "res://addons/gd-blender-3d-shortcuts/plugin.cfg", "res://addons/kanban_tasks/plugin.cfg")

[global_group]

worldPropWeapon=""

[importer_defaults]

scene={
"blender/materials/unpack_enabled": false,
"gltf/embedded_image_handling": 3,
"gltf/naming_version": 0
}

